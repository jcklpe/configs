# VS Code terminal integration - must load first
# [[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"

##- 𝒛𝖘𝖍 𝖘𝖕𝖊𝖑𝖑𝖇𝖔𝖔𝖐

# Initialize CONFIGS and PLUGINS (includes OS detection and setup)
source ~/configs/init.sh

# Load PATH tools and environment managers
source ${CONFIGS}/path.sh

##- zsh related
alias config="nano ~/.zshrc";
alias reload='source ~/.zshrc';

# Run nano with better defaults
alias nano='nano --const --mouse';

##- Theme Settings
export TERM="xterm-256color"

# Load appropriate prompt based on environment
if [[ "$TERM_PROGRAM" == "vscode" ]]; then
    # VS Code needs simple prompt (Powerlevel10k breaks terminal integration)
    source ${CONFIGS}/vscode/prompt.zsh
else
    # Use Powerlevel10k in regular terminals
    POWERLEVEL9K_MODE="nerdfont-complete"
    ZSH_DISABLE_COMPFIX=true
    source ${CONFIGS}/zsh/prompt.zsh
fi

##- Additional aliases
alias testbold='bold=$(tput bold) && normal=$(tput sgr0) && echo "this is ${bold}bold${normal} but this aint"'
alias testcolor='${PLUGINS}/Color-Scripts/color-scripts/colorview'
alias test256color='${PLUGINS}/Color-Scripts/test-color-support/color-support2'
alias mount='mount |column -t'

# function to run vscode as admin
function sudocode () {
  sudo code --user-data-dir="~/.vscode-root"
}

##- Scripts
source ${CONFIGS}/load-shell-modules.sh

##- PLUGINS
##- syntax highlighting
source ${PLUGINS}/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

##- Zsh Auto-suggestions
source ${PLUGINS}/zsh-autosuggestions/zsh-autosuggestions.zsh

##- jump directories
if command -v jump &>/dev/null; then
    eval "$(command jump shell zsh)"
    # Capture original j, rewrap to run lk after landing
    functions[_j_orig]=$functions[j]
    function j() { _j_orig "$@" && lk; }
    alias jmp='j'
fi

##- warp door
if [ -f "${PLUGINS}/wd/wd.plugin.zsh" ]; then
    # Redefine wd() to source wd.sh directly (same as plugin) + lk on navigation
    # Non-navigation subcommands skip lk
    function wd() {
        case "$1" in
            add|rm|remove|show|list|ls|path|clean|clean!|help|--help|-h|-v|--version|-d|-c|-q)
                source "${PLUGINS}/wd/wd.sh"
                ;;
            *)
                source "${PLUGINS}/wd/wd.sh" && lk
                ;;
        esac
    }
fi

##- you should use
source ${PLUGINS}/zsh-you-should-use/you-should-use.plugin.zsh

alias python='python3';

# trash-cli: safer rm (sends to trash instead of permanently deleting)
# brew installs as 'trash', linux trash-cli also provides 'trash'
if command -v trash &>/dev/null; then
    alias rm='trash'
fi

# Mark zshrc as loaded (prevents double-loading when sourced from zprofile)
export ZSHRC_LOADED=1
