{
  "accounts": [
    {
      "alias": "ut",
      "auth_provider": "graph-powershell",
      "tenant": "organizations",
      "mail": {
        "enabled": true,
        "days": 30,
        "max_results": 150,
        "body_character_limit": 8000
      },
      "calendar": {
        "enabled": true,
        "calendar_ids": ["primary"],
        "writable_calendar_ids": ["primary"],
        "timezone": "Central Standard Time",
        "description_character_limit": 8000
      },
      "contacts": {
        "enabled": true,
        "max_results": 500,
        "notes_character_limit": 4000
      }
    }
  ]
}
