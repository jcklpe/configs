# Copy this file to .env and fill in real local values.
# .env is ignored by git.

LIFEOS_VAULT_PATH="$HOME/path/to/LifeOS"
OPEN_AUSTIN_ORG_REPO_PATH="$HOME/work/org"
OPEN_AUSTIN_ORG_GITHUB_REPO="open-austin/org"

TRELLO_API_KEY="replace_me"
TRELLO_TOKEN="replace_me"
TRELLO_WRITE_TOKEN="replace_me"
TRELLO_BOARD_IDS="board_id_1,board_id_2"

GOOGLE_CALENDAR_CREDENTIALS_PATH="$CONFIGS/lifeos-tools/secrets/google-credentials.json"
GOOGLE_CALENDAR_TOKEN_PATH="$CONFIGS/lifeos-tools/secrets/google-token.json"
GOOGLE_CALENDAR_IDS="primary"
GOOGLE_ACCOUNTS_PATH="$CONFIGS/lifeos-tools/secrets/google-accounts.json"

# Optional. Local name->email map checked before the Google People API when
# resolving `--attendee NAME` for calendar invites. Defaults to
# lifeos-tools/secrets/people-aliases.json (copy people-aliases.example.json). Use it for
# frequent invitees whose bare first name is ambiguous in Google Contacts.
LIFEOS_PEOPLE_ALIASES_PATH="$CONFIGS/lifeos-tools/secrets/people-aliases.json"

# Comma-separated calendar IDs that `calendar create-event` / `update-event`
# are allowed to write to. Reads (sync) still see every calendar in
# GOOGLE_CALENDAR_IDS; this allowlist only gates writes so the agent cannot edit
# shared/work/partner calendars. Defaults to `primary` when unset.
LIFEOS_CALENDAR_WRITABLE_IDS="primary"

# Comma-separated calendar names (matched against the calendar summary,
# case-insensitive) whose event descriptions are noise. Descriptions for these
# calendars are omitted in `calendar sync`; all other calendars keep theirs.
# Verify exact names with `lifeos calendar list-calendars`.
LIFEOS_CALENDAR_NO_DESCRIPTION="Noisy Calendar One,Noisy Calendar Two"

LIFEOS_DAYS_BACK=14
LIFEOS_DAYS_AHEAD=30
