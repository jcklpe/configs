# Copy this file to .env and fill in real local values.
# .env is ignored by git.

LIFEOS_VAULT_PATH="$HOME/path/to/LifeOS"
OPEN_AUSTIN_ORG_REPO_PATH="$HOME/work/org"
OPEN_AUSTIN_ORG_GITHUB_REPO="open-austin/org"

TRELLO_API_KEY="replace_me"
TRELLO_TOKEN="replace_me"
TRELLO_WRITE_TOKEN="replace_me"
TRELLO_BOARD_IDS="board_id_1,board_id_2"

GOOGLE_CALENDAR_CREDENTIALS_PATH="$CONFIGS/lifeos-tools/google-credentials.json"
GOOGLE_CALENDAR_TOKEN_PATH="$CONFIGS/lifeos-tools/google-token.json"
GOOGLE_CALENDAR_IDS="primary"
GOOGLE_ACCOUNTS_PATH="$CONFIGS/lifeos-tools/google-accounts.json"

# Comma-separated calendar names (matched against the calendar summary,
# case-insensitive) whose event descriptions are noise. Descriptions for these
# calendars are omitted in `calendar sync`; all other calendars keep theirs.
# Verify exact names with `lifeos calendar list-calendars`.
LIFEOS_CALENDAR_NO_DESCRIPTION="Noisy Calendar One,Noisy Calendar Two"

LIFEOS_DAYS_BACK=14
LIFEOS_DAYS_AHEAD=30
